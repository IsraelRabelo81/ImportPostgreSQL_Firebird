<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.MainController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label text="Configuração PostgreSQL"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Host:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="pgHost" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Porta:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="pgPort" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Banco:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="pgDatabase" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Usuário:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="pgUser" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Senha:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <PasswordField fx:id="pgPassword" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <Label text="Configuração Firebird"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Caminho:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fbPath" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Usuário:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="fbUser" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Senha:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <PasswordField fx:id="fbPassword" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <Label text="Importar"/>

    <HBox spacing="10">
        <CheckBox fx:id="chkProduct" text="Produtos"/>
        <CheckBox fx:id="chkSupplier" text="Fornecedores"/>
        <CheckBox fx:id="chkClient" text="Clientes"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Testar Conexão" onAction="#onTestConnection"/>
        <Button text="Importar" onAction="#onImport"/>
    </HBox>

</VBox>